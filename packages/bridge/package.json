{
    "name": "artnet-bridge",
    "version": "0.0.0-git",
    "type": "module",
    "description": "ArtNet/DMX bridge to IoT lighting protocols",
    "main": "dist/esm/index.js",
    "bin": {
        "artnet-bridge": "dist/esm/cli.js"
    },
    "scripts": {
        "clean": "artnet-build clean",
        "build": "artnet-build",
        "build-clean": "artnet-build --clean",
        "bundle": "node scripts/copy-public.js"
    },
    "engines": {
        "node": ">=22.13.0"
    },
    "repository": {
        "type": "git",
        "url": "git+https://github.com/Apollon77/artnet-bridge.git"
    },
    "author": "Ingo Fischer",
    "license": "MIT",
    "bugs": {
        "url": "https://github.com/Apollon77/artnet-bridge/issues"
    },
    "homepage": "https://github.com/Apollon77/artnet-bridge",
    "dependencies": {
        "@artnet-bridge/artnet": "*",
        "@artnet-bridge/protocol": "*",
        "@artnet-bridge/protocol-hue": "*",
        "express": "^5.2.1",
        "ws": "^8.20.0"
    },
    "devDependencies": {
        "@types/express": "^5.0.6",
        "@types/node": "^25.6.0",
        "@types/ws": "^8.18.1"
    },
    "files": [
        "dist/**/*",
        "src/**/*",
        "LICENSE",
        "README.md"
    ],
    "publishConfig": {
        "access": "public"
    }
}
