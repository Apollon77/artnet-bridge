{
    "name": "@artnet-bridge/protocol",
    "version": "0.0.0-git",
    "type": "module",
    "description": "Base protocol types and interfaces for ArtNet Bridge",
    "main": "dist/esm/index.js",
    "exports": {
        ".": {
            "dev-types": {
                "types": "./src/index.ts"
            },
            "import": {
                "types": "./dist/esm/index.d.ts",
                "default": "./dist/esm/index.js"
            }
        }
    },
    "scripts": {
        "clean": "nacho-build clean",
        "build": "nacho-build",
        "build-clean": "nacho-build --clean"
    },
    "engines": {
        "node": ">=22.13.0"
    },
    "repository": {
        "type": "git",
        "url": "git+https://github.com/Apollon77/artnet-bridge.git"
    },
    "author": "Ingo Fischer",
    "license": "MIT",
    "bugs": {
        "url": "https://github.com/Apollon77/artnet-bridge/issues"
    },
    "homepage": "https://github.com/Apollon77/artnet-bridge",
    "devDependencies": {},
    "files": [
        "dist/**/*",
        "src/**/*",
        "LICENSE",
        "README.md"
    ],
    "publishConfig": {
        "access": "public"
    }
}
